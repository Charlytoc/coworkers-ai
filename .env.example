# Django Configuration
DEBUG=1
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,django

# Database Configuration
POSTGRES_DB=startup-db
POSTGRES_USER=startup-user
POSTGRES_PASSWORD=startup_password
POSTGRES_HOST=postgres

# Ports (override if defaults conflict with other local services)
# Host-side publish ports only (inside the network: Postgres 5432, Redis 6379, Flower 5555)
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# FLOWER_HOST_PORT=5555
DJANGO_PORT=8000
# Nginx reverse proxy — the single port you open in your browser during development.
# Routes /api/ and /admin/ → Django, /socket.io/ → Realtime, everything else → Next.js.
# Change if 9000 conflicts with another local service (e.g. AirPlay uses 7000).
ENTRYPOINT_PORT=9000

# Public URL of the Django API (used for Telegram webhooks). Use ngrok/devtunnel HTTPS in dev.
# Its hostname is added to ALLOWED_HOSTS automatically (e.g. *.ngrok-free.dev).
SITE_URL=http://127.0.0.1:8000
# Optional: comma-separated extra hosts (tunnel renames, staging domains, …).
# ALLOWED_HOSTS=other.example.com
# TELEGRAM_APPROVAL_CACHE_TTL=3600
REALTIME_PORT=3001
WEB_PORT=3000

# Redis Configuration (TCP port is always 6379 in app code; set host/URLs for AWS, etc.)
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# Celery Configuration (broker = Redis; task results = Postgres via django-celery-results)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db

# Django Superuser Configuration (for automatic creation)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@localhost.com
DJANGO_SUPERUSER_PASSWORD=p


# Optional: External API Keys
OPENAI_API_KEY=

# Fernet key for encrypting integration secrets (bot tokens, OAuth tokens).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_ENCRYPTION_KEY=

# Telegram integration
# Optional: how long (seconds) approval codes stay valid. Default: 3600.
# TELEGRAM_APPROVAL_CACHE_TTL=3600

# Instagram / Meta integration
# Create a Meta App at https://developers.facebook.com/apps/ (type: Business)
# Add products: Instagram + Facebook Login for Business.
#
# OAuth redirect URIs (must match exactly):
#   Instagram Business Login: {SITE_URL}/api/integrations/instagram/callback/
#   Facebook Login for Business: {SITE_URL}/api/integrations/instagram/facebook/callback/
#
# Facebook Login requests instagram_manage_comments, instagram_manage_insights,
# instagram_manage_contents, etc. App Review is required before Live Mode.
# Facebook Login for Business (App settings → Basic → App ID + App secret)
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
#
# Instagram Business Login (Instagram → API setup → Instagram app ID + secret)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Any random string you choose — enter the same value in Meta App Dashboard → Webhooks → Verify Token
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
# Comma-separated webhook fields for POST .../subscribed_apps (default: messages). Meta: Instagram Platform → Webhooks
INSTAGRAM_WEBHOOK_SUBSCRIBED_FIELDS=messages

# Frontend URL — used to redirect the browser back after Instagram OAuth completes
FRONTEND_URL=http://localhost:3000

# Container suffix for Docker Compose services in case, this is automatically generated by the taskfile.sh setup-env command
CONTAINER_SUFFIX=